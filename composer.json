{
    "name": "desafio6/realtime-panel",
    "type": "project",
    "description": "Painel de Monitoramento em Tempo Real com SSE",
    "require": {"php":"^8.2","laravel/framework":"^11.0","tymon/jwt-auth":"^2.1","predis/predis":"^2.2"},
    "require-dev": {"pestphp/pest":"^2.34","pestphp/pest-plugin-laravel":"^2.4","phpstan/phpstan":"^1.10","laravel/pint":"^1.14","fakerphp/faker":"^1.23","mockery/mockery":"^1.6"},
    "autoload": {"psr-4":{"App\\":"app/","Domain\\":"src/Domain/","Application\\":"src/Application/","Infrastructure\\":"src/Infrastructure/","Database\\Seeders\\":"database/seeders/"}},
    "autoload-dev": {"psr-4":{"Tests\\":"tests/"}},
    "scripts": {"test":"pest","lint":"pint","analyse":"phpstan analyse"},
    "config": {"optimize-autoloader":true,"preferred-install":"dist","sort-packages":true,"allow-plugins":{"pestphp/pest-plugin":true}},
    "minimum-stability": "stable","prefer-stable": true
}
